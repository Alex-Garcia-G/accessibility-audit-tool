# Copy this file to .env and fill in your values
# Never commit .env to git — it contains secrets

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database — matches docker-compose.yml defaults for local dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/accessibility_audit

# GitHub OAuth — create an app at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Session — any long random string (used to sign session cookies)
SESSION_SECRET=change_this_to_a_long_random_string

# Environment
NODE_ENV=development
PORT=3000
